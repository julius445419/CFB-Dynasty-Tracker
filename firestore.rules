rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: leagues
    // Fields: name (string), ownerId (string), createdAt (timestamp)
    //
    // Collection: seasons
    // Fields: leagueId (string), year (int), isCurrent (bool)
    //
    // Collection: teams
    // Fields: leagueId (string), name (string), ownerId (string), conference (string)
    //
    // Collection: games
    // Fields: week (int), homeTeamId (string), awayTeamId (string), homeScore (int), awayScore (int), status (string), leagueId (string), season (int)
    //
    // Collection: players
    // Fields: name (string), pos (string), year (string), ovr (int), teamId (string), hometown (string)
    //
    // Collection: teamStats
    // Fields: gameId (string), teamId (string), score (int), totalYards (int), passingYards (int), rushingYards (int), turnovers (int), firstDowns (int)
    //
    // Collection: playerStats
    // Fields: gameId (string), playerId (string), teamId (string), passYds (int), passTDs (int), etc.
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isLeagueOwner(leagueId) {
      return isAuthenticated() && get(/databases/$(database)/documents/leagues/$(leagueId)).data.ownerId == request.auth.uid;
    }

    function isValidLeague(data) {
      return data.keys().hasAll(['name', 'ownerId', 'createdAt']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.ownerId == request.auth.uid &&
             (!('currentYear' in data) || data.currentYear is int) &&
             (!('currentWeek' in data) || data.currentWeek is int);
    }

    function isValidTeam(data) {
      return data.keys().hasAll(['leagueId', 'name', 'coachName', 'coachRole']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.coachName is string && data.coachName.size() > 0 &&
             data.coachRole in ['HC', 'OC', 'DC'];
    }

    function isValidPlayer(data) {
      return data.keys().hasAll(['name', 'pos', 'number', 'height', 'weight', 'year', 'redshirt', 'ovr', 'teamId', 'leagueId', 'createdAt']) &&
             data.name is string && data.name.size() > 0 &&
             data.pos is string &&
             data.number is int &&
             data.height is string &&
             data.weight is int &&
             data.year in ['Freshman', 'Sophomore', 'Junior', 'Senior'] &&
             data.redshirt is bool &&
             data.ovr is int;
    }

    // Rules
    match /leagues/{leagueId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidLeague(request.resource.data);
      allow update: if isOwner(resource.data.ownerId) && isValidLeague(request.resource.data);
      allow delete: if isOwner(resource.data.ownerId);

      match /seasons/{seasonId} {
        allow read: if isAuthenticated();
        allow write: if isLeagueOwner(leagueId);
      }

      match /teams/{teamId} {
        allow read: if isAuthenticated();
        allow create, update: if isLeagueOwner(leagueId) && isValidTeam(request.resource.data);
        allow delete: if isLeagueOwner(leagueId);
      }

      match /stats/{statId} {
        allow read: if isAuthenticated();
        allow write: if isLeagueOwner(leagueId);
      }

      match /games/{gameId} {
        allow read: if isAuthenticated();
        allow create: if isLeagueOwner(leagueId) || 
                        (isAuthenticated() && 
                         (exists(/databases/$(database)/documents/leagues/$(leagueId)/teams/$(request.resource.data.homeTeamId)) && 
                          get(/databases/$(database)/documents/leagues/$(leagueId)/teams/$(request.resource.data.homeTeamId)).data.ownerId == request.auth.uid) ||
                         (exists(/databases/$(database)/documents/leagues/$(leagueId)/teams/$(request.resource.data.awayTeamId)) && 
                          get(/databases/$(database)/documents/leagues/$(leagueId)/teams/$(request.resource.data.awayTeamId)).data.ownerId == request.auth.uid));
        allow update, delete: if isLeagueOwner(leagueId) || 
                                (isAuthenticated() && 
                                 (exists(/databases/$(database)/documents/leagues/$(leagueId)/teams/$(resource.data.homeTeamId)) && 
                                  get(/databases/$(database)/documents/leagues/$(leagueId)/teams/$(resource.data.homeTeamId)).data.ownerId == request.auth.uid) ||
                                 (exists(/databases/$(database)/documents/leagues/$(leagueId)/teams/$(resource.data.awayTeamId)) && 
                                  get(/databases/$(database)/documents/leagues/$(leagueId)/teams/$(resource.data.awayTeamId)).data.ownerId == request.auth.uid));
      }

      match /players/{playerId} {
        allow read: if isAuthenticated();
        allow create, update: if (isLeagueOwner(leagueId) || 
                                 (isAuthenticated() && 
                                  exists(/databases/$(database)/documents/leagues/$(leagueId)/teams/$(request.resource.data.teamId)) && 
                                  get(/databases/$(database)/documents/leagues/$(leagueId)/teams/$(request.resource.data.teamId)).data.ownerId == request.auth.uid)) && 
                                isValidPlayer(request.resource.data);
        allow delete: if isLeagueOwner(leagueId) || 
                        (isAuthenticated() && 
                         exists(/databases/$(database)/documents/leagues/$(leagueId)/teams/$(resource.data.teamId)) && 
                         get(/databases/$(database)/documents/leagues/$(leagueId)/teams/$(resource.data.teamId)).data.ownerId == request.auth.uid);
      }

      match /teamStats/{statId} {
        allow read: if isAuthenticated();
        allow write: if isLeagueOwner(leagueId);
      }

      match /playerStats/{statId} {
        allow read: if isAuthenticated();
        allow write: if isLeagueOwner(leagueId);
      }
    }
    
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }
  }
}
