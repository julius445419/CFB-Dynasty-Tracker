rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isLeagueOwner(leagueId) {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/leagues/$(leagueId)).data.ownerId == request.auth.uid ||
         (exists(/databases/$(database)/documents/leagues/$(leagueId)/members/$(request.auth.uid)) && 
          (get(/databases/$(database)/documents/leagues/$(leagueId)/members/$(request.auth.uid)).data.role == 'owner' ||
           get(/databases/$(database)/documents/leagues/$(leagueId)/members/$(request.auth.uid)).data.role == 'commissioner')));
    }

    function canDeleteLeagueData(leagueId) {
      return isAuthenticated() && (
        get(/databases/$(database)/documents/leagues/$(leagueId)).data.ownerId == request.auth.uid ||
        (exists(/databases/$(database)/documents/leagues/$(leagueId)/members/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/leagues/$(leagueId)/members/$(request.auth.uid)).data.permissions.canDeleteLeague == true) ||
        isAdmin()
      );
    }

    function isAdmin() {
      return isAuthenticated() && 
        ((request.auth.token.email == "julius445419@gmail.com" && request.auth.token.email_verified == true) ||
         (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'));
    }

    // Validation Functions
    function isValidLeague(data) {
      return data.name is string && data.name.size() > 0;
    }

    function isValidTeam(data) {
      return data.name is string && data.school is string;
    }

    function isValidGame(data) {
      return data.leagueId is string && data.season is int;
    }

    function isValidUser(data) {
      return data.email is string;
    }

    function isValidProspect(data) {
      return data.name is string;
    }

    function isValidPlayer(data) {
      return data.name is string;
    }

    function isValidTeamStats(data) {
      return data.teamId is string && data.seasonYear is int;
    }

    // Rules
    match /leagues/{leagueId} {
      allow get, list: if isAuthenticated();
      allow create: if isAuthenticated() && isValidLeague(request.resource.data);
      allow update: if (isLeagueOwner(leagueId) || isAdmin()) && isValidLeague(request.resource.data);
      allow delete: if canDeleteLeagueData(leagueId);

      match /seasons/{seasonId} {
        allow read: if isAuthenticated();
        allow write: if isLeagueOwner(leagueId) || isAdmin();
        allow delete: if canDeleteLeagueData(leagueId);
      }

      match /teams/{teamId} {
        allow read: if isAuthenticated();
        allow create: if (isLeagueOwner(leagueId) || isAdmin() || (isAuthenticated() && request.resource.data.ownerId == 'cpu')) && isValidTeam(request.resource.data);
        allow update: if (isLeagueOwner(leagueId) || isAdmin()) && isValidTeam(request.resource.data);
        allow delete: if canDeleteLeagueData(leagueId);

        match /targets/{targetId} {
          allow read: if isAuthenticated();
          allow write: if isLeagueOwner(leagueId) || isAdmin();
          allow delete: if canDeleteLeagueData(leagueId);
        }
      }

      match /members/{memberId} {
        allow read: if isAuthenticated();
        allow write: if isLeagueOwner(leagueId) || isOwner(memberId) || isAdmin();
        allow delete: if canDeleteLeagueData(leagueId);
      }

      match /requests/{requestId} {
        allow read: if isLeagueOwner(leagueId) || isOwner(requestId) || isAdmin();
        allow create: if isAuthenticated();
        allow update: if isLeagueOwner(leagueId) || isAdmin();
        allow delete: if isLeagueOwner(leagueId) || isOwner(requestId) || isAdmin() || canDeleteLeagueData(leagueId);
      }

      match /stats/{statId} {
        allow read: if isAuthenticated();
        allow write: if isLeagueOwner(leagueId) || isAdmin();
        allow delete: if canDeleteLeagueData(leagueId);
      }

      match /games/{gameId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated() && isValidGame(request.resource.data);
        allow update: if isAuthenticated() && isValidGame(request.resource.data);
        allow delete: if isLeagueOwner(leagueId) || isAdmin() || canDeleteLeagueData(leagueId);
      }

      match /players/{playerId} {
        allow read: if isAuthenticated();
        allow create, update: if isAuthenticated() && isValidPlayer(request.resource.data);
        allow delete: if isLeagueOwner(leagueId) || isAdmin() || canDeleteLeagueData(leagueId);
      }

      match /team_stats/{statId} {
        allow read: if isAuthenticated();
        allow write: if (isLeagueOwner(leagueId) || isAdmin()) && isValidTeamStats(request.resource.data);
        allow delete: if canDeleteLeagueData(leagueId);
      }

      match /playerStats/{statId} {
        allow read: if isAuthenticated();
        allow write: if isAuthenticated();
        allow delete: if canDeleteLeagueData(leagueId);
      }

      match /prospects/{prospectId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated() && isValidProspect(request.resource.data);
        allow update: if isAuthenticated() && (isLeagueOwner(leagueId) || isAdmin() || resource.data.commitStatus != 'Committed');
        allow delete: if isLeagueOwner(leagueId) || isAdmin() || canDeleteLeagueData(leagueId);
      }

      match /activity_logs/{logId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated();
        allow update, delete: if isLeagueOwner(leagueId) || isAdmin() || canDeleteLeagueData(leagueId);
      }
    }
    
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if (isOwner(userId) || isAdmin()) && isValidUser(request.resource.data);
    }

    match /teams/{teamId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /coaches/{coachId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated() && (isLeagueOwner(request.resource.data.leagueId) || isLeagueOwner(resource.data.leagueId) || isAdmin());
      allow delete: if isAuthenticated() && (
        isLeagueOwner(resource.data.leagueId) ||
        get(/databases/$(database)/documents/leagues/$(resource.data.leagueId)/members/$(request.auth.uid)).data.permissions.canDeleteCoaches == true ||
        get(/databases/$(database)/documents/leagues/$(resource.data.leagueId)/members/$(request.auth.uid)).data.permissions.canDeleteLeague == true ||
        isAdmin()
      );
    }

    match /polls/{pollId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && (isLeagueOwner(request.resource.data.leagueId) || isAdmin());
      allow delete: if isAuthenticated() && canDeleteLeagueData(resource.data.leagueId);
    }

    // Collection Group Rules
    match /{path=**}/teams/{teamId} {
      allow read: if isAuthenticated();
    }

    match /{path=**}/members/{memberId} {
      allow read: if isAuthenticated();
    }
  }
}
