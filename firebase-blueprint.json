{
  "entities": {
    "League": {
      "title": "League",
      "description": "The main dynasty league object.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Name of the league." },
        "ownerId": { "type": "string", "description": "UID of the league creator." },
        "currentYear": { "type": "integer", "description": "The current year of the dynasty." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp." }
      },
      "required": ["name", "ownerId", "createdAt"]
    },
    "Season": {
      "title": "Season",
      "description": "A specific season within a league.",
      "type": "object",
      "properties": {
        "leagueId": { "type": "string", "description": "ID of the parent league." },
        "year": { "type": "integer", "description": "The year of the season (e.g., 2024)." },
        "isCurrent": { "type": "boolean", "description": "Whether this is the active season." }
      },
      "required": ["leagueId", "year"]
    },
    "Team": {
      "title": "Team",
      "description": "A team in the dynasty.",
      "type": "object",
      "properties": {
        "ownerId": { "type": "string", "description": "UID of the user controlling the team." },
        "ownerEmail": { "type": "string", "description": "Email of the user." },
        "firstName": { "type": "string", "description": "First name of the coach." },
        "lastName": { "type": "string", "description": "Last name of the coach." },
        "school": { "type": "string", "description": "Team name (e.g., Ohio State)." },
        "logoId": { "type": "string", "description": "ESPN logo ID." },
        "role": { "type": "string", "enum": ["HC", "OC", "DC"], "description": "Coach role." },
        "joinedAt": { "type": "string", "format": "date-time", "description": "When they joined." },
        "wins": { "type": "integer" },
        "losses": { "type": "integer" },
        "confWins": { "type": "integer" },
        "confLosses": { "type": "integer" },
        "pointsFor": { "type": "integer" },
        "pointsAgainst": { "type": "integer" },
        "passYards": { "type": "integer" },
        "rushYards": { "type": "integer" },
        "totalYards": { "type": "integer" },
        "passYardsAllowed": { "type": "integer" },
        "rushYardsAllowed": { "type": "integer" },
        "totalYardsAllowed": { "type": "integer" },
        "headCoachId": { "type": "string", "description": "Reference to the Coach document ID for HC." },
        "ocId": { "type": "string", "description": "Reference to the Coach document ID for OC." },
        "dcId": { "type": "string", "description": "Reference to the Coach document ID for DC." }
      },
      "required": ["ownerId", "school", "role"]
    },
    "Coach": {
      "title": "Coach",
      "description": "A standalone coach entity for the Coaching Carousel.",
      "type": "object",
      "properties": {
        "leagueId": { "type": "string", "description": "ID of the league this coach belongs to." },
        "name": { "type": "string", "description": "Full name of the coach." },
        "role": { "type": "string", "enum": ["HC", "OC", "DC", "Unassigned"], "description": "Current role." },
        "teamId": { "type": "string", "description": "ID of the team the coach is currently assigned to (null if free agent)." },
        "userId": { "type": "string", "description": "ID of the human user linked to this coach persona." },
        "careerWins": { "type": "integer" },
        "careerLosses": { "type": "integer" },
        "schoolWins": { "type": "integer" },
        "schoolLosses": { "type": "integer" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["leagueId", "name", "role"]
    },
    "GlobalTeam": {
      "title": "GlobalTeam",
      "description": "A college football team (FBS or FCS) available in the system.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "logoId": { "type": "string" },
        "conference": { "type": "string" },
        "color": { "type": "string" },
        "isFCS": { "type": "boolean", "description": "Whether this is a placeholder FCS team." }
      },
      "required": ["name", "logoId", "conference", "color"]
    },
    "Request": {
      "title": "Request",
      "description": "A request to join a league with a specific team.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "UID of the user." },
        "userEmail": { "type": "string", "description": "Email of the user." },
        "firstName": { "type": "string", "description": "First name of the coach." },
        "lastName": { "type": "string", "description": "Last name of the coach." },
        "school": { "type": "string", "description": "Desired school." },
        "logoId": { "type": "string", "description": "ESPN logo ID." },
        "role": { "type": "string", "enum": ["HC", "OC", "DC"], "description": "Desired role." },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"], "description": "Request status." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the request was made." }
      },
      "required": ["userId", "school", "role", "status"]
    },
    "Stat": {
      "title": "Stat",
      "description": "A statistical record for a player or team.",
      "type": "object",
      "properties": {
        "seasonId": { "type": "string", "description": "ID of the season." },
        "teamId": { "type": "string", "description": "ID of the team." },
        "playerName": { "type": "string", "description": "Name of the player." },
        "category": { "type": "string", "description": "Stat category (e.g., Passing, Rushing)." },
        "value": { "type": "number", "description": "The statistical value." }
      },
      "required": ["seasonId", "teamId", "playerName", "category", "value"]
    },
    "Prospect": {
      "title": "Prospect",
      "description": "A recruit in the league.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "pos": { "type": "string" },
        "stars": { "type": "integer" },
        "archetype": { "type": "string" },
        "hometown": { "type": "string" },
        "state": { "type": "string" },
        "height": { "type": "string" },
        "weight": { "type": "integer" },
        "ovr": { "type": "integer" },
        "leagueId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "pos", "stars", "leagueId"]
    },
    "Target": {
      "title": "Target",
      "description": "A prospect tracked by a specific team.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "pos": { "type": "string" },
        "stars": { "type": "integer" },
        "archetype": { "type": "string" },
        "hometown": { "type": "string" },
        "state": { "type": "string" },
        "height": { "type": "string" },
        "weight": { "type": "integer" },
        "ovr": { "type": "integer" },
        "leagueId": { "type": "string" },
        "teamId": { "type": "string" },
        "scoutingStatus": { "type": "string", "enum": ["Normal", "Gem", "Bust"] },
        "priority": { "type": "string", "enum": ["Low", "Med", "High", "Top Target"] },
        "notes": { "type": "string" },
        "topSchools": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "pos", "stars", "leagueId", "teamId", "scoutingStatus", "priority"]
    },
    "Game": {
      "title": "Game",
      "description": "A matchup between two teams.",
      "type": "object",
      "properties": {
        "week": { "type": "integer" },
        "homeTeamId": { "type": "string" },
        "awayTeamId": { "type": "string" },
        "homeScore": { "type": "integer" },
        "awayScore": { "type": "integer" },
        "status": { "type": "string", "enum": ["scheduled", "final"] },
        "leagueId": { "type": "string" },
        "season": { "type": "integer" },
        "quarterLengthAtGame": { "type": "integer", "description": "Quarter length in minutes used for TOP normalization." },
        "homeStats": { "$ref": "TeamStats" },
        "awayStats": { "$ref": "TeamStats" }
      },
      "required": ["week", "homeTeamId", "awayTeamId", "status", "leagueId", "season"]
    },
    "TeamStats": {
      "title": "TeamStats",
      "description": "Granular team statistics for a game.",
      "type": "object",
      "properties": {
        "passYards": { "type": "integer" },
        "rushYards": { "type": "integer" },
        "turnovers": { "type": "integer" },
        "takeaways": { "type": "integer" },
        "firstDowns": { "type": "integer" },
        "ypp": { "type": "number" },
        "rushingAttempts": { "type": "integer" },
        "rushingTds": { "type": "integer" },
        "completions": { "type": "integer" },
        "passingAttempts": { "type": "integer" },
        "passingTds": { "type": "integer" },
        "fumblesLost": { "type": "integer" },
        "interceptionsThrown": { "type": "integer" },
        "penalties": { "type": "integer" },
        "penaltyYards": { "type": "integer" },
        "timeOfPossession": { "type": "string", "description": "TOP in MM:SS format." }
      }
    },
    "Poll": {
      "title": "Poll",
      "description": "Weekly Top 25 rankings.",
      "type": "object",
      "properties": {
        "leagueId": { "type": "string" },
        "seasonYear": { "type": "integer" },
        "week": { "type": "integer" },
        "pollType": { "type": "string", "enum": ["Media", "Coaches", "CFP"] },
        "rankings": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "teamId": { "type": "string" },
              "rank": { "type": "integer" },
              "previousRank": { "type": "integer" }
            }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["leagueId", "seasonYear", "week", "pollType", "rankings"]
    },
    "User": {
      "title": "User",
      "description": "A human user account.",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "systemName": { "type": "string", "description": "The user's unique account identity (GamerTag)." },
        "email": { "type": "string" },
        "photoURL": { "type": "string" },
        "lastLogin": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["displayName", "systemName", "email"]
    }
  },
  "firestore": {
    "/users": { "schema": "User", "description": "Global collection of user profiles." },
    "/teams": { "schema": "GlobalTeam", "description": "Global list of all schools (FBS and FCS)." },
    "/leagues": { "schema": "League", "description": "Collection of dynasty leagues." },
    "/leagues/{leagueId}/seasons": { "schema": "Season", "description": "Seasons for a specific league." },
    "/leagues/{leagueId}/teams": { "schema": "Team", "description": "Teams in a specific league." },
    "/leagues/{leagueId}/stats": { "schema": "Stat", "description": "Stats for a specific league." },
    "/leagues/{leagueId}/games": { "schema": "Game", "description": "Matchups for a specific league." },
    "/leagues/{leagueId}/teamStats": { "schema": "TeamStats", "description": "Granular team stats (if stored separately)." },
    "/leagues/{leagueId}/prospects": { "schema": "Prospect", "description": "Global pool of recruits for the league." },
    "/leagues/{leagueId}/teams/{teamId}/targets": { "schema": "Target", "description": "Recruits tracked by a specific team." },
    "/coaches": { "schema": "Coach", "description": "Standalone coaches for the Coaching Carousel." },
    "/polls": { "schema": "Poll", "description": "Weekly Top 25 polls." }
  }
}
